#!/usr/bin/env bash
set -euo pipefail

./script/build

node \
  --experimental-test-coverage \
  --test-coverage-include='src/lib/render.ts' \
  --test-coverage-include='src/lib/helpers/*.ts' \
  --test-coverage-lines=95 \
  --test-coverage-functions=95 \
  --test-coverage-branches=85 \
  --test \
  test/*.test.ts
